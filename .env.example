# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Rachio ---
# Your Rachio "API Key" (app -> Account Settings -> Get API Key). One key covers
# every controller on the account. Consolidate all your controllers onto ONE Rachio
# account first (guest/shared controllers are invisible to the API).
# Either RACHIO_API_KEY or RACHIO_API_TOKEN is accepted.
RACHIO_API_KEY=

# --- Storage ---
DATABASE_PATH=data/watertool.db

# --- Webhook ingestion ---
# Public HTTPS base URL where THIS receiver is reachable from the internet
# (Rachio must be able to POST to it). e.g. https://water.example.com
PUBLIC_BASE_URL=
WEBHOOK_PATH=/webhooks/rachio

# How to authenticate inbound webhooks: hmac | basic | none
#   hmac  -> new Rachio WebhookService: x-signature = HMAC-SHA256(body, API token)
#   basic -> legacy webhooks: HTTP basic auth embedded in the registered URL
#   none  -> accept anything (dev only)
WEBHOOK_VERIFY=hmac
WEBHOOK_BASIC_USER=rachio
WEBHOOK_BASIC_PASS=

# --- Jobs ---
BACKFILL_DAYS=365
RECONCILE_OVERLAP_DAYS=2
